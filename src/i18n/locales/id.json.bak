  "legal": {
    "about": {
      "title": "About FIRE Calculator",
      "subtitle": "A free, privacy-first tool for planning your path to financial independence",
      "mission": {
        "title": "Our Mission",
        "content": "To provide accessible, privacy-respecting financial planning tools that help everyone pursue financial independence — without compromising their personal data."
      },
      "whatIsFireTitle": "What is FIRE?",
      "whatIsFireContent": "FIRE (Financial Independence, Retire Early) is a lifestyle movement focused on achieving financial freedom through aggressive saving and smart investing. The goal is to accumulate enough wealth that your investments can cover your living expenses indefinitely, giving you the freedom to retire much earlier than traditional retirement age.",
      "corePrincipleTitle": "Core Principle",
      "corePrincipleContent": "The \"4% Rule\" suggests that if you withdraw 4% of your portfolio annually, your savings should last 30+ years. This means you need approximately 25x your annual expenses to achieve FIRE.",
      "goalTitle": "The Goal",
      "goalContent": "Financial independence means having enough passive income (from investments) to cover your living expenses, giving you freedom to choose how you spend your time — whether that's early retirement, part-time work, or pursuing passion projects.",
      "typesTitle": "Types of FIRE",
      "fireTypes": {
        "standard": {
          "title": "Standard FIRE",
          "desc": "The classic 25x annual expenses approach. Full financial independence with no need for additional income."
        },
        "coast": {
          "title": "Coast FIRE",
          "desc": "Save enough now so compound growth carries you to traditional retirement. Stop saving early and \"coast\" to FI."
        },
        "lean": {
          "title": "Lean FIRE",
          "desc": "FI with a frugal lifestyle. Lower expenses mean a smaller target number, achieved faster."
        },
        "fat": {
          "title": "Fat FIRE",
          "desc": "FI with a comfortable or luxurious lifestyle. Higher expenses require a larger portfolio."
        },
        "barista": {
          "title": "Barista FIRE",
          "desc": "Partial FI combined with part-time work. Leave full-time corporate work earlier while maintaining some income."
        }
      },
      "toolsTitle": "Our Calculators",
      "toolsIntro": "We offer a comprehensive suite of calculators to help you plan every aspect of your FIRE journey:",
      "tools": {
        "standardFire": {
          "title": "Standard FIRE Calculator",
          "desc": "Calculate your FIRE number and timeline to full financial independence."
        },
        "coastFire": {
          "title": "Coast FIRE Calculator",
          "desc": "Find your Coast FIRE number — when you can stop saving and let compound growth finish the job."
        },
        "leanFatFire": {
          "title": "Lean & Fat FIRE",
          "desc": "Calculate FI targets for minimalist or comfortable lifestyles."
        },
        "baristaFire": {
          "title": "Barista FIRE Calculator",
          "desc": "Blend part-time work with investment income for earlier semi-retirement."
        },
        "withdrawalRate": {
          "title": "Withdrawal Rate Calculator",
          "desc": "Test portfolio longevity and find your safe withdrawal rate."
        },
        "savingsRate": {
          "title": "Savings Rate Calculator",
          "desc": "Calculate your savings rate and see how it impacts your FIRE timeline."
        }
      },
      "whyChooseTitle": "Why Choose FIRE Calculator?",
      "features": {
        "free": {
          "title": "100% Free",
          "desc": "No subscriptions, no premium tiers, no hidden fees. All calculators are completely free to use."
        },
        "privacy": {
          "title": "Privacy First",
          "desc": "Your financial data stays in your browser. No accounts, no databases, no server processing."
        },
        "offline": {
          "title": "Works Offline",
          "desc": "After initial load, the app works without internet. Install as a PWA and calculate anywhere."
        },
        "noTracking": {
          "title": "No Tracking",
          "desc": "No analytics, no cookies, no third-party trackers. Your usage is completely private."
        },
        "shareable": {
          "title": "Shareable URLs",
          "desc": "Save calculations in URLs. Bookmark, share with a partner, or revisit later — your data is in the link."
        },
        "openSource": {
          "title": "Open Source",
          "desc": "All code is publicly available. Verify our privacy claims yourself — transparency is key."
        }
      },
      "openSourceTitle": "Open Source",
      "openSource": {
        "content": "This calculator is open source, meaning anyone can inspect, verify, and contribute to the code. We believe transparency builds trust — especially for financial tools.",
        "githubTitle": "GitHub Repository",
        "githubUrl": "github.com/jamesmontemagno/app-fire-calculator",
        "note": "Feel free to explore the code, report issues, suggest features, or contribute improvements. We welcome community involvement and feedback."
      },
      "learnMoreTitle": "Learn More",
      "learnMoreIntro": "Explore our curated resources to deepen your understanding of financial independence:",
      "learnMore": {
        "books": "Recommended Books",
        "apps": "Recommended Apps",
        "quiz": "Find Your FIRE Path"
      },
      "disclaimer": {
        "title": "Disclaimer",
        "content": "This calculator is for educational and informational purposes only. It is not financial, investment, tax, or legal advice. Results are hypothetical projections based on user inputs and assumed rates. Actual results will vary. Please consult a qualified financial advisor before making any financial decisions.",
        "link": "Read our full Terms of Service"
      },
      "navigation": {
        "startCalculating": "← Start Calculating",
        "privacyPolicy": "Privacy Policy →",
        "termsOfService": "Terms of Service →"
      }
    },
    "whoWeAre": {
      "title": "Who We Are",
      "content": "FIRE Calculator is an open-source project built by and for the FIRE (Financial Independence, Retire Early) community. We're a small team of developers and financial enthusiasts who believe everyone deserves access to quality financial planning tools.",
      "team": "Our Team",
      "teamDesc": "We're volunteers and contributors from around the world, united by our passion for financial education and privacy-first technology."
    },
    "whyFree": {
      "title": "Why This is Free",
      "content": "We believe financial planning tools should be accessible to everyone. Here's how we keep the lights on while staying free:",
      "reasons": {
        "ads": {
          "title": "Ethical Advertising",
          "desc": "We display Google AdSense ads to cover server costs. No tracking, no data selling."
