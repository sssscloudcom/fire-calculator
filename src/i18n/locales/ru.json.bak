  "home": {
    "title": "Калькуляторы FIRE",
    "subtitle": "Планируйте свой путь к финансовой независимости и раннему выходу на пенсию. Бесплатно, конфиденциально и полностью работает оффлайн.",
    "badges": {
      "private": "100% Конфиденциально",
      "offline": "Работает оффлайн",
      "noTracking": "Без отслеживания",
      "shareable": "URL для обмена"
    },
    "quiz": {
      "title": "Не уверены, какой калькулятор использовать?",
      "desc": "Пройдите наш быстрый тест, чтобы найти идеальный путь FIRE для вашей ситуации. Ответьте на несколько вопросов, и мы порекомендуем лучший калькулятор с предзаполненной информацией.",
      "cta": "Найдите свой путь FIRE",
      "note": "Занимает 2-3 минуты · Персонализированная рекомендация"
    },
    "chooseCalculator": "Выберите ваш калькулятор",
    "startCalculating": "Начать расчёт",
    "books": {
      "title": "Рекомендуемые книги по FIRE",
      "subtitle": "Важное чтение для ускорения вашего пути к финансовой независимости.",
      "viewAll": "Посмотреть все книги и подробности",
      "affiliateNote": "Партнёрские ссылки — покупки поддерживают этот бесплатный калькулятор без дополнительных затрат для вас."
    },
    "privacy": {
      "title": "Ваша конфиденциальность — наш приоритет",
      "subtitle": "Мы создали этот калькулятор с принципами приоритета конфиденциальности.",
      "features": {
        "noStorage": {
          "title": "Без хранения финансовых данных",
          "desc": "Ваши финансовые данные остаются только в URL — никогда не сохраняются. Только настройки интерфейса (тема, макет) хранятся локально."
        },
        "noAnalytics": {
          "title": "Без аналитики",
          "desc": "Ноль скриптов отслеживания. Без Google Analytics, без стороннего кода."
        },
        "urlBased": {
          "title": "Обмен через URL",
          "desc": "Сохраняйте расчёты в URL. Закладки или обмен — ваш выбор."
        },
        "worksOffline": {
          "title": "Работает оффлайн",
          "desc": "После первой загрузки работает без интернета. Можно установить как приложение на ваше устройство."
        },
        "openSource": {
          "title": "Открытый исходный код",
          "desc": "Проверьте всё сами. Весь код доступен на GitHub."
        },
        "clientSide": {
          "title": "Только на стороне клиента",
          "desc": "Все расчёты выполняются в вашем браузере. Без серверной обработки."
        }
      }
    },
    "whatIsFire": {
      "title": "Что такое FIRE?",
      "para1": "FIRE означает Financial Independence, Retire Early (Финансовая Независимость, Ранний Выход на Пенсию). Это финансовое движение, сосредоточенное на экстремальных сбережениях и инвестициях для выхода на пенсию гораздо раньше традиционного пенсионного возраста. Основной принцип прост: агрессивно копите, мудро инвестируйте, и как только ваши инвестиции смогут покрывать ваши жизненные расходы бесконечно, вы достигаете финансовой независимости.",
      "para2": "Самый распространённый расчёт FIRE использует правило 4% (или правило 25x): если вы можете жить на 4% вашего портфеля в год, вам нужно накопить 25 раз ваши годовые расходы. Например, если вы тратите $40,000 в год, вам нужно $1,000,000 для финансовой независимости."
    },
    "tallyAi": {
      "title": "Отслеживайте прогресс с Tally AI",
      "desc": "Умный финансовый помощник, который помогает отслеживать расходы, управлять бюджетом и достигать целей FIRE с помощью AI-инсайтов. Идеальное дополнение к этим калькуляторам.",
      "cta": "Узнать больше о Tally AI"
    },
    "disclaimer": {
      "title": "Отказ от ответственности",
      "content": "Этот калькулятор предоставляется только в образовательных и информационных целях. Это не финансовая, инвестиционная, налоговая или юридическая консультация. Результаты являются гипотетическими прогнозами, и фактические результаты будут отличаться. Пожалуйста, проконсультируйтесь с квалифицированным финансовым консультантом перед принятием любых финансовых решений."
    },
    "builtWith": "Создано с учётом конфиденциальности. Данные никогда не покидают ваш браузер.",
