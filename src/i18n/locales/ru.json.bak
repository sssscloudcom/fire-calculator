  "privacy": {
    "title": "Privacy Policy",
    "lastUpdated": "Last updated: June 2025",
    "summary": {
      "title": "TL;DR: Your Privacy is Our Priority",
      "points": {
        "browserSide": "All calculations happen 100% in your browser",
        "noCollection": "We do not collect, store, or transmit any personal or financial information",
        "noAccounts": "No user accounts, no databases, no server-side processing",
        "noTracking": "No tracking, no analytics, no cookies for user data"
      }
    },
    "sections": {
      "infoCollect": {
        "title": "1. Information We Collect",
        "intro": "We do not collect any personal or financial information. This FIRE Calculator is designed with privacy as a core principle. Here's what that means:",
        "dontCollect": "What We DON'T Collect:",
        "items": {
          "names": "Names, email addresses, or contact information",
          "financial": "Financial data (income, expenses, savings, investments)",
          "ip": "IP addresses or location data",
          "browsing": "Browsing history or usage patterns",
          "cookies": "Cookies for tracking purposes"
        }
      },
      "howCalculations": {
        "title": "2. How Your Calculations Work",
        "intro": "All calculations are performed entirely within your web browser (client-side). When you enter financial information:",
        "steps": {
          "browserSide": {
            "title": "Browser-Side Processing",
            "desc": "All mathematical calculations happen in JavaScript running in your browser. No data is sent to our servers."
          },
          "urlStorage": {
            "title": "URL-Based Storage (Optional)",
            "desc": "Your calculation inputs are encoded in the URL when you share or bookmark. This is the only way your data persists — and it's entirely under your control."
          },
          "noServer": {
            "title": "No Server Transmission",
            "desc": "Your financial data is never transmitted to our servers for processing, storage, or any other purpose."
          }
        }
      },
      "localStorage": {
        "title": "3. Local Storage Usage",
        "intro": "We use browser local storage to save non-sensitive preferences only. This data never leaves your device:",
        "table": {
          "dataStored": "Data Stored",
          "purpose": "Purpose",
          "containsFinancial": "Contains Financial Data?",
          "theme": "Theme preference",
          "themePurpose": "Remember dark/light mode",
          "language": "Language preference",
          "languagePurpose": "Remember language selection",
          "sidebar": "Sidebar collapsed state",
          "sidebarPurpose": "Remember UI layout",
          "no": "No"
        },
        "clearNote": "You can clear this data at any time through your browser settings. Clearing local storage will not affect your calculations — it only resets your preferences to defaults."
      },
      "thirdParty": {
        "title": "4. Third-Party Services",
        "googleAdsense": {
          "title": "Google AdSense",
          "intro": "We use Google AdSense to display advertisements. Google AdSense may collect certain information to serve relevant ads, including:",
          "items": {
            "device": "Device information (browser type, operating system)",
            "location": "General location (country/region level)",
            "adInteraction": "Ad interaction data"
          },
          "important": "Important: Google's ad tracking is independent of our calculator. Your financial calculations and inputs are never shared with Google or any advertiser."
        },
        "amazonAffiliate": {
          "title": "Amazon Affiliate Links",
          "content": "Some book recommendations include Amazon affiliate links. When you click these links, Amazon may collect data according to their privacy policy. This does not affect your calculator usage or data."
        }
      },
      "noTracking": {
        "title": "5. No Tracking Policy",
        "items": {
          "noAnalytics": {
            "title": "No Google Analytics",
            "desc": "We don't use Google Analytics or similar tracking tools."
          },
          "noPixel": {
            "title": "No Facebook Pixel",
            "desc": "No social media tracking pixels."
          },
          "noUserTracking": {
            "title": "No User Tracking",
            "desc": "We don't track individual users or sessions."
          },
          "noCrossSite": {
            "title": "No Cross-Site Tracking",
            "desc": "We don't follow you across other websites."
          }
        }
      },
      "dataSecurity": {
        "title": "6. Data Security",
        "content": "Since all calculations happen locally in your browser and we don't collect any data, there's no database to breach. Your financial information is as secure as your own device. We recommend:",
        "recommendations": {
          "browser": "Using a secure, up-to-date browser",
          "device": "Keeping your device protected with a password or biometric lock",
          "urls": "Being cautious when sharing URLs that contain your financial calculations"
        }
      },
      "yourRights": {
        "title": "7. Your Rights",
        "intro": "Because we don't collect or store your personal data, many data protection rights are automatically satisfied:",
        "rights": {
          "access": "Right to Access: All your data is in your browser — you have complete access.",
          "deletion": "Right to Deletion: Clear your browser data to delete everything.",
          "portability": "Right to Portability: Your calculation URLs contain all your data in portable form.",
          "object": "Right to Object: No processing to object to — your data stays with you."
        }
      },
      "changes": {
        "title": "8. Changes to This Policy",
        "content": "We may update this privacy policy from time to time. We will notify users of any material changes by posting the new policy on this page with an updated \"Last updated\" date."
      },
      "contact": {
        "title": "9. Contact Us",
        "content": "If you have questions about this privacy policy, you can:",
        "aboutPage": "Visit our",
        "aboutPageSuffix": "for more information about the project",
        "github": "View the"
      }
    },
    "navigation": {
      "termsOfService": "Terms of Service →",
      "aboutUs": "About Us →"
    }
  },
